# Copy this file to .env and fill in your values

# ── Database ───────────────────────────────────────────────
# Use "sqlite" for local dev (zero config), "postgresql" for production
DB_DRIVER=sqlite

# PostgreSQL settings (only needed when DB_DRIVER=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_dw
DB_USER=postgres
DB_PASSWORD=your_password_here
